# BankScan — Environment Configuration Example
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Application ────────────────────────────────────────────────────
APP_NAME=BankScan
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# ── Upload Limits ──────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50
MAX_PDF_PAGES=60

# ── File Paths (relative to backend/ directory) ────────────────────
UPLOAD_DIR=uploads
OUTPUT_DIR=outputs

# ── CORS ───────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=["http://localhost:3000"]

# ── Future: MongoDB ────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=bankscan

# ── Future: JWT Authentication ─────────────────────────────────────
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── Admin Panel ────────────────────────────────────────────────────
# Required value of the X-Admin-Token header for /api/v1/admin/* routes
ADMIN_API_TOKEN=change-me-in-production-use-openssl-rand-hex-32
